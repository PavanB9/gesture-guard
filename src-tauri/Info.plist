<dict>
  <!-- The Python sidecar opens the webcam; on macOS that access is attributed
       to this app, so the TCC prompt needs a usage description. -->
  <key>NSCameraUsageDescription</key>
  <string>Gesture Guard analyzes your webcam locally to blur the feed when it detects unprofessional gestures. Video never leaves your device.</string>
</dict>
